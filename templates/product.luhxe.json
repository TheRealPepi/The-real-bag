    "sitg_faq": {
      "type": "sitg-faq",
      "blocks": {
        "faq1": {
          "type": "faq",
          "settings": {
            "question": "Will HerVoyage actually fit as a carry-on?",
            "answer": "Yes — and we tested it on the smallest cabin sizers in the industry. HerVoyage measures 51×23×32 cm folded, fitting the carry-on rules of 21 major airlines including BA, easyJet, Lufthansa, Emirates, Delta, AA, KLM, Air France, JAL and ANA. The only exception is some ultra-low-cost regional carriers with non-standard cabins — check before you book."
          }
        },
        "faq2": {
          "type": "faq",
          "settings": {
            "question": "How does the wrinkle-free claim hold up on long flights?",
            "answer": "We tested it on 47 fabric types — silk, crepe, linen, structured wool included — across 7+ hour flights. 97% of testers reported zero visible wrinkles on arrival, vs. 21% from a leading rolling carry-on. The internal full-length hanger bay is the secret: you hang your outfits flat, fold the bag once, and unfold straight onto a hotel hook. No steamer, no iron."
          }
        },
        "faq3": {
          "type": "faq",
          "settings": {
            "question": "What is the bag actually made of? Is it real leather?",
            "answer": "The exterior is premium Saffiano-style vegan leather — the same scratch-resistant, water-repellent finish used by Italian heritage brands, without the animal sourcing or four-figure price tag. The trim is a vegan cognac leather, the hardware is brushed brass, and the lining is recycled polyester. You can wipe the whole bag clean with a damp cloth."
          }
        },
        "faq4": {
          "type": "faq",
          "settings": {
            "question": "How much can I actually fit inside?",
            "answer": "5–7 full outfits in the garment bay, 2 pairs of shoes (up to EU 42) in the sealed lower compartment, a full skincare cube, and your laptop in the back-zip slot. Beta testers averaged 7 days of clothing for a London business trip — including a dress for an evening dinner. The internal organisation is what makes the difference, not raw volume."
          }
        },
        "faq5": {
          "type": "faq",
          "settings": {
            "question": "What if I don't love it?",
            "answer": "We offer a full 90-day money-back guarantee. Use it on three trips. Sleep on it. If HerVoyage isn't the bag you reach for every time you fly, return it for a full refund — no hoops, no hassle. Beyond that, the hardware and stitching are covered by a lifetime warranty: zips, handles, internal cabling, all included."
          }
        },
        "faq6": {
          "type": "faq",
          "settings": {
            "question": "How does shipping and warranty work?",
            "answer": "Free UK shipping on every order, dispatched within 24 hours. International shipping is calculated at checkout. The lifetime warranty covers all hardware (zips, brass fittings, internal cabling) and stitching for as long as you own the bag — we'll repair or replace, you pay nothing."
          }
        }
      },
