<div class="sitg">
<section class="sitg-ingredients" id="features">
  <div class="sitg-container">
    <div class="reveal">
      <div class="section-eyebrow">{{ section.settings.eyebrow }}</div>
      <div class="section-title">{{ section.settings.headline }}</div>
      <p class="section-subtitle">{{ section.settings.subtitle }}</p>
    </div>
    <div class="sitg-ingredient-grid">
      {%- for block in section.blocks -%}
        <div class="sitg-ingredient-card sitg-ic-{{ forloop.index }} reveal" {{ block.shopify_attributes }}>
          <div class="sitg-ic-number">0{{ forloop.index }}</div>
          <span class="sitg-ic-branded">{{ block.settings.branded_name }}</span>
          <div class="sitg-ic-name">{{ block.settings.ingredient_name }}</div>
          <div class="sitg-ic-dose">{{ block.settings.dose }}</div>
          <div class="sitg-ic-mechanism">{{ block.settings.mechanism_icon }} {{ block.settings.mechanism_name }}</div>
          <p class="sitg-ic-body">{{ block.settings.description }}</p>
          <div class="sitg-ic-stat">
            <div class="sitg-ic-stat-num">{{ block.settings.stat_number }}</div>
            <div class="sitg-ic-stat-label">{{ block.settings.stat_label }}</div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>
</div>

{% schema %}
{
  "name": "SITG Ingredients",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "What's inside" },
    { "type": "textarea", "id": "headline", "label": "Headline (HTML allowed)", "default": "FOUR DETAILS.<br>FOUR REASONS<br>WOMEN NEVER GO BACK." },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle", "default": "Every detail of HerVoyage was designed by a flight attendant who'd lived the problem on 2,000+ flights." }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Feature card",
      "settings": [
        { "type": "text", "id": "branded_name", "label": "Feature subhead", "default": "Saffiano-grade vegan leather" },
        { "type": "text", "id": "ingredient_name", "label": "Feature name", "default": "EXTERIOR FINISH" },
        { "type": "text", "id": "dose", "label": "Spec line", "default": "Premium-grade · scratch & water resistant" },
        { "type": "text", "id": "mechanism_icon", "label": "Icon", "default": "✨" },
        { "type": "text", "id": "mechanism_name", "label": "Benefit", "default": "Looks new every flight" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "The same Saffiano-style finish used by Italian heritage houses — without the four-figure price tag, and without the leather. Resists scratches, repels water, wipes clean with a damp cloth." },
        { "type": "text", "id": "stat_number", "label": "Stat number", "default": "0" },
        { "type": "textarea", "id": "stat_label", "label": "Stat label", "default": "scuffs after our 50-flight stress test." }
      ]
    }
  ],
  "presets": [
    { "name": "SITG Ingredients" }
  ]
}
{% endschema %}
