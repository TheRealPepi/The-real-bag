<div class="sitg">
<section class="sitg-reframe">
  <div class="sitg-container">
    {%- if section.settings.section_image != blank -%}
      <div class="sitg-reframe-header reveal">
        <div class="sitg-reframe-header-text">
          <div class="sitg-reframe-eyebrow">{{ section.settings.eyebrow }}</div>
          <h2>{{ section.settings.headline }}</h2>
          <p class="sitg-reframe-body">{{ section.settings.body }}</p>
        </div>
        <div class="sitg-reframe-header-img">
          <img
            src="{{ section.settings.section_image | image_url: width: 800 }}"
            alt="{{ section.settings.section_image.alt | default: 'Active lifestyle' }}"
            loading="lazy"
          >
        </div>
      </div>
    {%- else -%}
      <div class="sitg-reframe-inner reveal">
        <div class="sitg-reframe-eyebrow">{{ section.settings.eyebrow }}</div>
        <h2>{{ section.settings.headline }}</h2>
        <p class="sitg-reframe-body">{{ section.settings.body }}</p>
      </div>
    {%- endif -%}
  </div>
</section>
</div>

{% schema %}
{
  "name": "SITG Problem Reframe",
  "settings": [
    {
      "type": "image_picker",
      "id": "section_image",
      "label": "Lifestyle image (displays beside headline)"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "EVERY OTHER BAG MAKES YOU CHOOSE"
    },
    {
      "type": "textarea",
      "id": "headline",
      "label": "Headline (HTML allowed)",
      "default": "Beautiful or practical. Not anymore."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body text (HTML allowed)",
      "default": "For a decade I lived out of carry-ons. Every bag forced a choice — beautiful or practical, never both. Women were told to pack less, check a bag, keep it simple. We say: bring everything, pay nothing extra, arrive perfect. HerVoyage was built around one woman's schedule — and that woman never stops."
    }
  ],
  "blocks": [],
  "presets": [
    { "name": "SITG Problem Reframe" }
  ]
}
{% endschema %}
