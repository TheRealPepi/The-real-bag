<div class="sitg">
<section class="sitg-science" id="science">
  <div class="sitg-container sitg-science-inner">
    {%- if section.settings.section_image != blank -%}
      <div class="sitg-science-header reveal">
        <div class="sitg-science-header-text">
          <div class="section-eyebrow" style="color:var(--sitg-amber);">{{ section.settings.eyebrow }}</div>
          <div class="section-title" style="color:var(--sitg-green-deep);">{{ section.settings.headline }}</div>
        </div>
        <div class="sitg-science-header-img">
          <img
            src="{{ section.settings.section_image | image_url: width: 800 }}"
            alt="{{ section.settings.section_image.alt | default: 'Clinical science' }}"
            loading="lazy"
          >
        </div>
      </div>
    {%- else -%}
      <div style="text-align:center;margin-bottom:64px;" class="reveal">
        <div class="section-eyebrow" style="color:var(--sitg-amber);">{{ section.settings.eyebrow }}</div>
        <div class="section-title" style="color:var(--sitg-green-deep);">{{ section.settings.headline }}</div>
      </div>
    {%- endif -%}

    <div class="sitg-nsaid-block reveal">
      <h3>{{ section.settings.nsaid_headline }}</h3>
      <p>{{ section.settings.nsaid_body }}</p>
      <div class="sitg-nsaid-grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'nsaid_trial' -%}
            <div class="sitg-nsaid-card" {{ block.shopify_attributes }}>
              <div class="nc-ingredient">{{ block.settings.ingredient }}</div>
              <div class="nc-vs">{{ block.settings.vs }}</div>
              <div class="nc-result">{{ block.settings.result }}</div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>
</div>

{% schema %}
{
  "name": "SITG Science",
  "settings": [
    { "type": "image_picker", "id": "section_image", "label": "Lifestyle image (displays beside headline)" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "How we tested" },
    { "type": "textarea", "id": "headline", "label": "Headline (HTML allowed)", "default": "HERVOYAGE VS.<br>THE BAG YOU OWN NOW." },
    { "type": "text", "id": "nsaid_headline", "label": "Comparison headline", "default": "ONE HEAD-TO-HEAD. NO MARKETING SPIN." },
    { "type": "textarea", "id": "nsaid_body", "label": "Comparison intro", "default": "We packed both bags identically for a 7-night trip — same outfits, same shoes, same skincare cube — and ran them through real cabin conditions. Here's what came out the other side:" }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        { "type": "text", "id": "number", "label": "Number", "default": "21" },
        { "type": "text", "id": "label", "label": "Label", "default": "Major airlines verified for carry-on compliance" }
      ]
    },
    {
      "type": "nsaid_trial",
      "name": "Head-to-head comparison",
      "settings": [
        { "type": "text", "id": "ingredient", "label": "What's being compared", "default": "HerVoyage vs. standard rolling carry-on" },
        { "type": "text", "id": "vs", "label": "Test conditions", "default": "7-night packed test · all garment categories" },
        { "type": "textarea", "id": "result", "label": "Result", "default": "Held 38% more outfits with zero wrinkling vs. 24% wrinkle rate from the rolling case (pack-test panel, n=42)" }
      ]
    }
  ],
  "presets": [
    { "name": "SITG Science" }
  ]
}
{% endschema %}
