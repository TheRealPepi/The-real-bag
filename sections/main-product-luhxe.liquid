<product-info
  id="MainProduct-{{ section.id }}"
  class="luhxe-product section-{{ section.id }}-padding gradient color-{{ section.settings.color_scheme }}"
  data-section="{{ section.id }}"
  data-product-id="{{ product.id }}"
  data-update-url="true"
  data-url="{{ product.url }}"
>
  {{ 'section-main-product.css' | asset_url | stylesheet_tag }}
  {{ 'main-product-luhxe.css' | asset_url | stylesheet_tag }}
  {{ 'sitg-landing.css' | asset_url | stylesheet_tag }}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Caveat:wght@600&display=swap" rel="stylesheet">
  {{ 'component-price.css' | asset_url | stylesheet_tag }}
  {{ 'component-slider.css' | asset_url | stylesheet_tag }}
  {{ 'component-rating.css' | asset_url | stylesheet_tag }}
  {{ 'component-deferred-media.css' | asset_url | stylesheet_tag }}

  {% unless product.has_only_default_variant %}
    {{ 'component-product-variant-picker.css' | asset_url | stylesheet_tag }}
    {{ 'component-swatch-input.css' | asset_url | stylesheet_tag }}
    {{ 'component-swatch.css' | asset_url | stylesheet_tag }}
  {% endunless %}

  {%- style -%}
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }
    @media screen and (min-width: 750px) {
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }
    }
  {%- endstyle -%}

  <script src="{{ 'product-info.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
  {%- if request.design_mode -%}
    <script src="{{ 'theme-editor.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}

  {%- assign product_form_id = 'product-form-' | append: section.id -%}
  {%- assign variant_images = product.images | where: 'attached_to_variant?', true | map: 'src' -%}

  <div class="page-width">
    <div class="luhxe-product__grid product product--{{ section.settings.media_size }} product--{{ section.settings.media_position }} product--{{ section.settings.gallery_layout }} product--mobile-{{ section.settings.mobile_thumbnails }} grid grid--1-col{% if product.media.size > 0 %} grid--2-col-tablet{% else %} product--no-media{% endif %}">
      <div class="luhxe-product__media-wrapper product__media-wrapper grid__item">
        {%- if section.settings.featured_in_image != blank -%}
          <div class="luhxe-product__featured-in" aria-hidden="true">
            <img
              src="{{ section.settings.featured_in_image | image_url: width: 280 }}"
              alt="{{ section.settings.featured_in_image.alt | escape }}"
              width="140"
              height="140"
              loading="eager"
            >
          </div>
        {%- endif -%}

        {% render 'product-media-gallery', variant_images: variant_images %}
      </div>

      <div class="luhxe-product__info-wrapper product__info-wrapper grid__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        <section
          id="ProductInfo-{{ section.id }}"
          class="luhxe-product__info{% if section.settings.enable_sticky_info %} product__column-sticky{% endif %}"
        >
          {%- if section.blocks.size > 0 -%}
            {%- assign trust_badges = section.blocks | where: 'type', 'trust_badge' -%}
            {%- if trust_badges.size > 0 -%}
              <ul class="luhxe-trust-badges" role="list">
                {%- for block in trust_badges -%}
                  <li class="luhxe-trust-badge" {{ block.shopify_attributes }}>
                    {%- if block.settings.icon != blank -%}
                      <span class="luhxe-trust-badge__icon" aria-hidden="true">{{ block.settings.icon }}</span>
                    {%- endif -%}
                    <span class="luhxe-trust-badge__text">{{ block.settings.text }}</span>
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          {%- endif -%}

          {%- if section.settings.show_reviews -%}
            <div class="luhxe-reviews">
              <span class="luhxe-reviews__stars" aria-hidden="true">
                {%- for i in (1..5) -%}★{%- endfor -%}
              </span>
              {%- if section.settings.reviews_link != blank -%}
                <a href="{{ section.settings.reviews_link }}" class="luhxe-reviews__count">
                  {{- section.settings.reviews_count_text -}}
                </a>
              {%- else -%}
                <span class="luhxe-reviews__count">{{ section.settings.reviews_count_text }}</span>
              {%- endif -%}
            </div>
          {%- endif -%}

          <h1 class="luhxe-product__title">{{ product.title | escape }}</h1>

          {%- if section.settings.subtitle != blank -%}
            <p class="luhxe-product__subtitle">{{ section.settings.subtitle }}</p>
          {%- endif -%}

          <div id="price-{{ section.id }}" class="luhxe-product__price" role="status">
            {%- render 'price',
              product: product,
              use_variant: true,
              show_badges: true,
              price_class: 'price--large'
            -%}
          </div>

          {%- unless product.has_only_default_variant -%}
            <div class="luhxe-product__variant-header">
              <span class="luhxe-product__variant-heading">{{ section.settings.variant_picker_heading }}</span>
              {%- if section.settings.which_one_text != blank -%}
                {%- if section.settings.which_one_link != blank -%}
                  <a href="{{ section.settings.which_one_link }}" class="luhxe-product__which-one">
                    <span class="luhxe-product__which-one-icon" aria-hidden="true">i</span>
                    {{ section.settings.which_one_text }}
                  </a>
                {%- else -%}
                  <span class="luhxe-product__which-one">
                    <span class="luhxe-product__which-one-icon" aria-hidden="true">i</span>
                    {{ section.settings.which_one_text }}
                  </span>
                {%- endif -%}
              {%- endif -%}
            </div>

            {%- assign variant_picker_block = null -%}
            {%- capture variant_picker_block_id -%}variant-picker-{{ section.id }}{%- endcapture -%}
            {% render 'product-variant-picker',
              product: product,
              block: section,
              product_form_id: product_form_id
            %}
          {%- endunless -%}

          {%- if section.settings.kaching_placeholder -%}
            <div class="luhxe-product__kaching-placeholder" data-kaching-bundles="true">
              {%- comment -%}
                Kaching Bundles app injects its bundle UI here. Remove this block if Kaching is disabled.
              {%- endcomment -%}
            </div>
          {%- endif -%}

          <div class="luhxe-product__form">
            <product-form
              class="product-form"
              data-section-id="{{ section.id }}"
            >
              <div class="product-form__error-message-wrapper" role="alert" hidden>
                <span class="svg-wrapper">
                  {{- 'icon-error.svg' | inline_asset_content -}}
                </span>
                <span class="product-form__error-message"></span>
              </div>

              {%- form 'product',
                product,
                id: product_form_id,
                class: 'form',
                novalidate: 'novalidate',
                data-type: 'add-to-cart-form'
              -%}
                <input
                  type="hidden"
                  name="id"
                  value="{{ product.selected_or_first_available_variant.id }}"
                  {% if product.selected_or_first_available_variant.available == false %}
                    disabled
                  {% endif %}
                  class="product-variant-id"
                >

                <div class="product-form__buttons">
                  <button
                    id="ProductSubmitButton-{{ section.id }}"
                    type="submit"
                    name="add"
                    class="luhxe-product__add-to-cart product-form__submit button button--primary button--full-width"
                    {% if product.selected_or_first_available_variant.available == false %}
                      disabled
                    {% endif %}
                  >
                    <span>
                      {%- if product.selected_or_first_available_variant.available == false -%}
                        {{ 'products.product.sold_out' | t }}
                      {%- else -%}
                        {{ section.settings.button_text | default: 'Add to cart' }}
                      {%- endif -%}
                    </span>
                    <div class="loading__spinner hidden">
                      <svg
                        aria-hidden="true"
                        focusable="false"
                        class="spinner"
                        viewBox="0 0 66 66"
                        xmlns="http://www.w3.org/2000/svg"
                      >
                        <circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
                      </svg>
                    </div>
                  </button>
                </div>
              {%- endform -%}
            </product-form>
          </div>

          {%- if product.description != blank and section.settings.show_description -%}
            <div class="luhxe-product__description rte">
              {{ product.description }}
            </div>
          {%- endif -%}
        </section>
      </div>
    </div>

    {% render 'product-media-modal', variant_images: variant_images %}

    {%- if product.media.size > 0 -%}
      <script src="{{ 'product-modal.js' | asset_url }}" defer="defer"></script>
      <script src="{{ 'media-gallery.js' | asset_url }}" defer="defer"></script>
    {%- endif -%}

    <script type="application/ld+json">
      {{ product | structured_data }}
    </script>
  </div>
</product-info>

{% schema %}
{
  "name": "Product · Luhxe",
  "tag": "section",
  "class": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "media_size",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ],
      "default": "large",
      "label": "Media size"
    },
    {
      "type": "select",
      "id": "gallery_layout",
      "options": [
        { "value": "stacked", "label": "Stacked" },
        { "value": "thumbnail", "label": "Thumbnails" },
        { "value": "thumbnail_slider", "label": "Thumbnail slider" }
      ],
      "default": "thumbnail",
      "label": "Desktop gallery layout"
    },
    {
      "type": "select",
      "id": "media_position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left",
      "label": "Desktop media position"
    },
    {
      "type": "select",
      "id": "mobile_thumbnails",
      "options": [
        { "value": "show", "label": "Show" },
        { "value": "hide", "label": "Hide" }
      ],
      "default": "hide",
      "label": "Mobile thumbnails"
    },
    {
      "type": "select",
      "id": "image_zoom",
      "options": [
        { "value": "lightbox", "label": "Lightbox" },
        { "value": "hover", "label": "Hover" },
        { "value": "none", "label": "None" }
      ],
      "default": "lightbox",
      "label": "Image zoom"
    },
    {
      "type": "checkbox",
      "id": "constrain_to_viewport",
      "label": "Constrain media to viewport",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "hide_variants",
      "label": "Hide other variant images after selection",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_video_looping",
      "label": "Loop videos",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_sticky_info",
      "label": "Sticky product info on desktop",
      "default": true
    },
    {
      "type": "header",
      "content": "Featured-in badge"
    },
    {
      "type": "image_picker",
      "id": "featured_in_image",
      "label": "Featured-in image (e.g. Vogue)",
      "info": "Shown as a circular overlay on the product gallery"
    },
    {
      "type": "header",
      "content": "Reviews"
    },
    {
      "type": "checkbox",
      "id": "show_reviews",
      "label": "Show review stars",
      "default": true
    },
    {
      "type": "text",
      "id": "reviews_count_text",
      "label": "Reviews text",
      "default": "1346 Reviews"
    },
    {
      "type": "url",
      "id": "reviews_link",
      "label": "Reviews link"
    },
    {
      "type": "header",
      "content": "Product info"
    },
    {
      "type": "richtext",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "<p>Pack smarter, travel lighter, and skip the luggage fees—all in style</p>"
    },
    {
      "type": "header",
      "content": "Variant picker"
    },
    {
      "type": "text",
      "id": "variant_picker_heading",
      "label": "Heading above variants",
      "default": "Select Model"
    },
    {
      "type": "select",
      "id": "picker_type",
      "label": "Picker type",
      "options": [
        { "value": "button", "label": "Buttons" },
        { "value": "dropdown", "label": "Dropdown" }
      ],
      "default": "button"
    },
    {
      "type": "select",
      "id": "swatch_shape",
      "label": "Swatch shape",
      "options": [
        { "value": "circle", "label": "Circle" },
        { "value": "square", "label": "Square" },
        { "value": "none", "label": "None" }
      ],
      "default": "circle"
    },
    {
      "type": "text",
      "id": "which_one_text",
      "label": "Helper link text",
      "default": "Which one is for me?"
    },
    {
      "type": "url",
      "id": "which_one_link",
      "label": "Helper link URL"
    },
    {
      "type": "header",
      "content": "Buy button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Add-to-cart label",
      "default": "ADD TO CART"
    },
    {
      "type": "checkbox",
      "id": "kaching_placeholder",
      "label": "Render Kaching bundles container",
      "info": "Outputs an empty div above the buy button for the Kaching app to inject into.",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show product description",
      "default": false
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "trust_badge",
      "name": "Trust badge",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (emoji or short text)",
          "default": "✈️"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Carry-on approved on 100+ Airlines"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product · Luhxe",
      "blocks": [
        { "type": "trust_badge", "settings": { "icon": "✈️", "text": "Carry-on approved on 100+ Airlines" } },
        { "type": "trust_badge", "settings": { "icon": "🎁", "text": "FREE GIFTS WORTH $35" } },
        { "type": "trust_badge", "settings": { "icon": "🏆", "text": "2026 TOP-RATED TRAVEL BAG" } }
      ]
    }
  ]
}
{% endschema %}
