<product-info
  id="MainProduct-{{ section.id }}"
  class="luhxe-product section-{{ section.id }}-padding gradient color-{{ section.settings.color_scheme }}"
  data-section="{{ section.id }}"
  data-product-id="{{ product.id }}"
  data-update-url="true"
  data-url="{{ product.url }}"
>
  {{ 'section-main-product.css' | asset_url | stylesheet_tag }}
  {{ 'main-product-luhxe.css' | asset_url | stylesheet_tag }}
  {{ 'sitg-landing.css' | asset_url | stylesheet_tag }}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Caveat:wght@600&display=swap" rel="stylesheet">
  {{ 'component-price.css' | asset_url | stylesheet_tag }}
  {{ 'component-slider.css' | asset_url | stylesheet_tag }}
  {{ 'component-rating.css' | asset_url | stylesheet_tag }}
  {{ 'component-deferred-media.css' | asset_url | stylesheet_tag }}

  {% unless product.has_only_default_variant %}
    {{ 'component-product-variant-picker.css' | asset_url | stylesheet_tag }}
    {{ 'component-swatch-input.css' | asset_url | stylesheet_tag }}
    {{ 'component-swatch.css' | asset_url | stylesheet_tag }}
  {% endunless %}

  {%- style -%}
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }
    @media screen and (min-width: 750px) {
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }
    }
  {%- endstyle -%}

  <script src="{{ 'product-info.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
  {%- if request.design_mode -%}
    <script src="{{ 'theme-editor.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}

  {%- assign product_form_id = 'product-form-' | append: section.id -%}

  {%- liquid
    assign thumbs_pos = section.settings.thumbnails_position | default: 'bottom'
    assign gallery_max_w = section.settings.gallery_max_width | default: 640
    assign show_thumbs = true
    if thumbs_pos == 'hidden' or product.media.size < 2
      assign show_thumbs = false
    endif
    assign vertical_thumbs = false
    if thumbs_pos == 'left' or thumbs_pos == 'right'
      assign vertical_thumbs = true
    endif
  -%}

  <div class="page-width">
    <div class="luhxe-product__grid grid grid--1-col{% if product.media.size > 0 %} grid--2-col-tablet{% else %} product--no-media{% endif %}">
      <div class="luhxe-product__media-wrapper grid__item">
        {%- if section.settings.featured_in_image != blank -%}
          <div class="luhxe-product__featured-in" aria-hidden="true">
            <img
              src="{{ section.settings.featured_in_image | image_url: width: 280 }}"
              alt="{{ section.settings.featured_in_image.alt | escape }}"
              width="140"
              height="140"
              loading="eager"
            >
          </div>
        {%- endif -%}

        {%- if product.media.size > 0 -%}
          <div
            class="sitg-gallery sitg-gallery--thumbs-{{ thumbs_pos }}{% if vertical_thumbs %} sitg-gallery--vertical{% endif %}{% if product.media.size < 2 %} sitg-gallery--single{% endif %}"
            data-section-id="{{ section.id }}"
            data-variant-switching="{{ section.settings.enable_variant_switching }}"
            style="--sitg-max-w: {{ gallery_max_w }}px;"
            role="region"
            aria-roledescription="carousel"
            aria-label="Product media"
          >
            <div class="sitg-gallery__stage" data-sitg-stage>
              {%- for media in product.media -%}
                {%- assign is_first = forloop.first -%}
                {%- assign aspect = media.preview_image.aspect_ratio | default: 1.0 -%}
                <figure
                  class="sitg-gallery__slide{% if is_first %} is-active{% endif %}"
                  data-media-id="{{ media.id }}"
                  data-media-type="{{ media.media_type }}"
                  style="--sitg-aspect: {{ aspect }};"
                  {% unless is_first %}aria-hidden="true"{% endunless %}
                >
                  {%- case media.media_type -%}
                    {%- when 'image' -%}
                      <img
                        class="sitg-gallery__img"
                        srcset="
                          {%- if media.preview_image.width >= 360 %}{{ media.preview_image | image_url: width: 360 }} 360w,{% endif -%}
                          {%- if media.preview_image.width >= 540 %}{{ media.preview_image | image_url: width: 540 }} 540w,{% endif -%}
                          {%- if media.preview_image.width >= 720 %}{{ media.preview_image | image_url: width: 720 }} 720w,{% endif -%}
                          {%- if media.preview_image.width >= 900 %}{{ media.preview_image | image_url: width: 900 }} 900w,{% endif -%}
                          {%- if media.preview_image.width >= 1080 %}{{ media.preview_image | image_url: width: 1080 }} 1080w,{% endif -%}
                          {%- if media.preview_image.width >= 1296 %}{{ media.preview_image | image_url: width: 1296 }} 1296w,{% endif -%}
                          {%- if media.preview_image.width >= 1512 %}{{ media.preview_image | image_url: width: 1512 }} 1512w,{% endif -%}
                          {%- if media.preview_image.width >= 1728 %}{{ media.preview_image | image_url: width: 1728 }} 1728w,{% endif -%}
                          {%- if media.preview_image.width >= 2048 %}{{ media.preview_image | image_url: width: 2048 }} 2048w,{% endif -%}
                          {{ media.preview_image | image_url }} {{ media.preview_image.width }}w"
                        src="{{ media.preview_image | image_url: width: 1080 }}"
                        sizes="(min-width: 750px) min({{ gallery_max_w }}px, 50vw), 100vw"
                        alt="{{ media.alt | escape }}"
                        width="1080"
                        height="{{ 1080 | divided_by: aspect | ceil }}"
                        {% if is_first %}loading="eager" fetchpriority="high"{% else %}loading="lazy"{% endif %}
                      >

                    {%- when 'video' -%}
                      {{ media | media_tag: image_size: '2048x', controls: true, preload: 'metadata', class: 'sitg-gallery__video' }}

                    {%- when 'external_video' -%}
                      <div class="sitg-gallery__embed">
                        {%- if media.host == 'youtube' -%}
                          {{ media | external_video_url: playlist: media.external_id | external_video_tag: class: 'sitg-gallery__iframe', loading: 'lazy' }}
                        {%- else -%}
                          {{ media | external_video_tag: class: 'sitg-gallery__iframe', loading: 'lazy' }}
                        {%- endif -%}
                      </div>

                    {%- when 'model' -%}
                      {{ media | media_tag: image_size: '2048x', toggleable: true, class: 'sitg-gallery__model' }}

                    {%- else -%}
                      <img
                        class="sitg-gallery__img"
                        src="{{ media.preview_image | image_url: width: 1080 }}"
                        alt="{{ media.alt | escape }}"
                        loading="lazy"
                      >
                  {%- endcase -%}
                </figure>
              {%- endfor -%}
            </div>

            {%- if show_thumbs -%}
              <ul class="sitg-gallery__thumbs" data-sitg-thumbs role="list">
                {%- for media in product.media -%}
                  <li class="sitg-gallery__thumb-item">
                    <button
                      type="button"
                      class="sitg-gallery__thumb{% if forloop.first %} is-active{% endif %}"
                      data-thumb-for="{{ media.id }}"
                      aria-label="View media {{ forloop.index }} of {{ product.media.size }}{% if media.media_type != 'image' %} ({{ media.media_type }}){% endif %}"
                      {% if forloop.first %}aria-current="true"{% endif %}
                    >
                      <img
                        src="{{ media.preview_image | image_url: width: 200 }}"
                        srcset="{{ media.preview_image | image_url: width: 200 }} 1x, {{ media.preview_image | image_url: width: 400 }} 2x"
                        alt=""
                        width="100"
                        height="{{ 100 | divided_by: media.preview_image.aspect_ratio | ceil }}"
                        loading="lazy"
                      >
                      {%- unless media.media_type == 'image' -%}
                        <span class="sitg-gallery__thumb-badge" aria-hidden="true">
                          {%- if media.media_type == 'model' -%}3D{%- else -%}▶{%- endif -%}
                        </span>
                      {%- endunless -%}
                    </button>
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}

            <div class="visually-hidden" data-sitg-status role="status" aria-live="polite"></div>
          </div>
        {%- else -%}
          <div class="sitg-gallery__placeholder">
            {{ 'product-1' | placeholder_svg_tag: 'sitg-gallery__placeholder-svg' }}
          </div>
        {%- endif -%}
      </div>

      <div class="luhxe-product__info-wrapper product__info-wrapper grid__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        <section
          id="ProductInfo-{{ section.id }}"
          class="luhxe-product__info{% if section.settings.enable_sticky_info %} product__column-sticky{% endif %}"
        >
          {%- comment -%} TOP ZONE — trust badges (grouped) and reviews summary {%- endcomment -%}
          {%- assign trust_badges = section.blocks | where: 'type', 'trust_badge' -%}
          {%- if trust_badges.size > 0 -%}
            <ul class="luhxe-trust-badges" role="list">
              {%- for block in trust_badges -%}
                <li class="luhxe-trust-badge" {{ block.shopify_attributes }}>
                  {%- if block.settings.icon != blank -%}
                    <span class="luhxe-trust-badge__icon" aria-hidden="true">{{ block.settings.icon }}</span>
                  {%- endif -%}
                  <span class="luhxe-trust-badge__text">{{ block.settings.text }}</span>
                </li>
              {%- endfor -%}
            </ul>
          {%- endif -%}

          {%- for block in section.blocks -%}
            {%- if block.type == 'reviews_summary' -%}
              <div class="luhxe-reviews-summary" {{ block.shopify_attributes }}>
                <span
                  class="luhxe-stars"
                  style="color: {{ block.settings.star_color | default: '#b91c1c' }};"
                  aria-label="5 out of 5 stars"
                  role="img"
                >★★★★★</span>
                {%- if block.settings.count_text != blank -%}
                  {%- if block.settings.link != blank -%}
                    <a href="{{ block.settings.link }}" class="luhxe-reviews-summary__count">{{ block.settings.count_text }}</a>
                  {%- else -%}
                    <span class="luhxe-reviews-summary__count">{{ block.settings.count_text }}</span>
                  {%- endif -%}
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- endfor -%}

          <h1 class="luhxe-product__title">{{ product.title | escape }}</h1>

          {%- if section.settings.subtitle != blank -%}
            <div class="luhxe-product__subtitle">{{ section.settings.subtitle }}</div>
          {%- endif -%}

          {%- comment -%} MIDDLE + BOTTOM ZONE — reorderable blocks (price, variant picker, buy button, Kaching, app blocks, guarantee, accordions, featured review, benefits list) {%- endcomment -%}
          {%- assign reorderable_types = 'price,variant_picker,buy_button,kaching_placeholder,guarantee_badge,accordion_row,featured_review,benefits_list,benefit_item' | split: ',' -%}
          {%- assign has_reorderable_blocks = false -%}
          {%- for block in section.blocks -%}
            {%- if reorderable_types contains block.type or block.type == '@app' -%}
              {%- assign has_reorderable_blocks = true -%}
              {%- break -%}
            {%- endif -%}
          {%- endfor -%}

          {%- if has_reorderable_blocks -%}
            <div class="luhxe-product__bottom">
              {%- assign in_benefits_list = false -%}
              {%- for block in section.blocks -%}
                {%- comment -%} Auto-close an open benefits list when any non-list block appears {%- endcomment -%}
                {%- if in_benefits_list and block.type != 'benefit_item' and block.type != 'benefits_list' -%}
                  </ul></div>
                  {%- assign in_benefits_list = false -%}
                {%- endif -%}
                {%- case block.type -%}
                  {%- when 'price' -%}
                    <div id="price-{{ section.id }}" class="luhxe-product__price" role="status" {{ block.shopify_attributes }}>
                      {%- render 'price',
                        product: product,
                        use_variant: true,
                        show_badges: true,
                        price_class: 'price--large'
                      -%}
                    </div>

                  {%- when 'variant_picker' -%}
                    {%- unless product.has_only_default_variant -%}
                      <div class="luhxe-product__variant-header" {{ block.shopify_attributes }}>
                        <span class="luhxe-product__variant-heading">{{ block.settings.variant_picker_heading }}</span>
                        {%- if block.settings.which_one_text != blank -%}
                          {%- if block.settings.which_one_link != blank -%}
                            <a href="{{ block.settings.which_one_link }}" class="luhxe-product__which-one">
                              <span class="luhxe-product__which-one-icon" aria-hidden="true">i</span>
                              {{ block.settings.which_one_text }}
                            </a>
                          {%- else -%}
                            <span class="luhxe-product__which-one">
                              <span class="luhxe-product__which-one-icon" aria-hidden="true">i</span>
                              {{ block.settings.which_one_text }}
                            </span>
                          {%- endif -%}
                        {%- endif -%}
                      </div>

                      {% render 'product-variant-picker',
                        product: product,
                        block: block,
                        product_form_id: product_form_id
                      %}
                    {%- endunless -%}

                  {%- when 'kaching_placeholder' -%}
                    <div class="luhxe-product__kaching-placeholder" data-kaching-bundles="true" {{ block.shopify_attributes }}></div>

                  {%- when 'buy_button' -%}
                    <div class="luhxe-product__form" {{ block.shopify_attributes }}>
                      <product-form
                        class="product-form"
                        data-section-id="{{ section.id }}"
                      >
                        <div class="product-form__error-message-wrapper" role="alert" hidden>
                          <span class="svg-wrapper">
                            {{- 'icon-error.svg' | inline_asset_content -}}
                          </span>
                          <span class="product-form__error-message"></span>
                        </div>

                        {%- form 'product',
                          product,
                          id: product_form_id,
                          class: 'form',
                          novalidate: 'novalidate',
                          data-type: 'add-to-cart-form'
                        -%}
                          <input
                            type="hidden"
                            name="id"
                            value="{{ product.selected_or_first_available_variant.id }}"
                            {% if product.selected_or_first_available_variant.available == false %}
                              disabled
                            {% endif %}
                            class="product-variant-id"
                          >

                          <div class="product-form__buttons">
                            <button
                              id="ProductSubmitButton-{{ section.id }}"
                              type="submit"
                              name="add"
                              class="luhxe-product__add-to-cart product-form__submit button button--primary button--full-width"
                              {% if product.selected_or_first_available_variant.available == false %}
                                disabled
                              {% endif %}
                            >
                              <span>
                                {%- if product.selected_or_first_available_variant.available == false -%}
                                  {{ 'products.product.sold_out' | t }}
                                {%- else -%}
                                  {{ block.settings.button_text | default: 'Add to cart' }}
                                {%- endif -%}
                              </span>
                              <div class="loading__spinner hidden">
                                <svg
                                  aria-hidden="true"
                                  focusable="false"
                                  class="spinner"
                                  viewBox="0 0 66 66"
                                  xmlns="http://www.w3.org/2000/svg"
                                >
                                  <circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
                                </svg>
                              </div>
                            </button>
                          </div>
                        {%- endform -%}
                      </product-form>
                    </div>

                  {%- when '@app' -%}
                    {% render block %}

                  {%- when 'guarantee_badge' -%}
                    <div class="luhxe-guarantee-badge" {{ block.shopify_attributes }}>
                      {%- if block.settings.icon != blank -%}
                        <span class="luhxe-guarantee-badge__icon" aria-hidden="true">{{ block.settings.icon }}</span>
                      {%- endif -%}
                      <span class="luhxe-guarantee-badge__label">{{ block.settings.label }}</span>
                    </div>

                  {%- when 'accordion_row' -%}
                    <details
                      class="luhxe-accordion__row"
                      {% if block.settings.default_open %}open{% endif %}
                      {{ block.shopify_attributes }}
                    >
                      <summary class="luhxe-accordion__title">
                        <span>{{ block.settings.title | escape }}</span>
                        <span class="luhxe-accordion__chevron" aria-hidden="true"></span>
                      </summary>
                      <div class="luhxe-accordion__body rte">{{ block.settings.body }}</div>
                    </details>

                  {%- when 'benefits_list' -%}
                    {%- if in_benefits_list -%}</ul></div>{%- endif -%}
                    <div class="luhxe-benefits" style="--luhxe-check-color: {{ block.settings.check_color | default: '#1A1A1A' }};" {{ block.shopify_attributes }}>
                      {%- if block.settings.heading != blank -%}
                        <h3 class="luhxe-benefits__heading">{{ block.settings.heading | escape }}</h3>
                      {%- endif -%}
                      <ul class="luhxe-benefits__list">
                    {%- assign in_benefits_list = true -%}

                  {%- when 'benefit_item' -%}
                    {%- unless in_benefits_list -%}
                      <div class="luhxe-benefits"><ul class="luhxe-benefits__list">
                      {%- assign in_benefits_list = true -%}
                    {%- endunless -%}
                    <li class="luhxe-benefits__item" {{ block.shopify_attributes }}>
                      <span class="luhxe-benefits__icon" aria-hidden="true">
                        <svg viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg" focusable="false"><polyline points="3.5,8.5 6.8,11.5 12.5,5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      </span>
                      <span class="luhxe-benefits__text">{{ block.settings.text | escape }}</span>
                    </li>

                  {%- when 'featured_review' -%}
                    <div class="luhxe-featured-review" {{ block.shopify_attributes }}>
                      {%- if block.settings.photo != blank -%}
                        <div class="luhxe-featured-review__photo">
                          {{ block.settings.photo | image_url: width: 96 | image_tag: width: 48, height: 48, loading: 'lazy', alt: block.settings.name }}
                        </div>
                      {%- endif -%}
                      <div class="luhxe-featured-review__content">
                        {%- if block.settings.quote != blank -%}
                          <p class="luhxe-featured-review__quote">{{ block.settings.quote }}</p>
                        {%- endif -%}
                        {%- if block.settings.name != blank -%}
                          <p class="luhxe-featured-review__name">
                            <em>{{ block.settings.name | escape }}</em>
                            <span class="luhxe-featured-review__stars" aria-hidden="true">★★★★★</span>
                          </p>
                        {%- endif -%}
                      </div>
                    </div>
                {%- endcase -%}
              {%- endfor -%}
              {%- if in_benefits_list -%}</ul></div>{%- endif -%}
            </div>
          {%- endif -%}

          {%- if product.description != blank and section.settings.show_description -%}
            <div class="luhxe-product__description rte">
              {{ product.description }}
            </div>
          {%- endif -%}
        </section>
      </div>
    </div>

    <script type="application/ld+json">
      {{ product | structured_data }}
    </script>
  </div>

  <script>
    (function () {
      var root = document.querySelector('.sitg-gallery[data-section-id="{{ section.id }}"]');
      if (!root) return;

      var slides = root.querySelectorAll('[data-sitg-stage] .sitg-gallery__slide');
      var thumbs = root.querySelectorAll('[data-sitg-thumbs] .sitg-gallery__thumb');
      var status = root.querySelector('[data-sitg-status]');
      if (!slides.length) return;

      function activate(mediaId) {
        var matched = false;
        slides.forEach(function (s) {
          var on = s.getAttribute('data-media-id') === String(mediaId);
          s.classList.toggle('is-active', on);
          if (on) { s.removeAttribute('aria-hidden'); matched = true; }
          else { s.setAttribute('aria-hidden', 'true'); }
          if (!on) {
            var v = s.querySelector('video');
            if (v && !v.paused) { try { v.pause(); } catch (e) {} }
            var iframe = s.querySelector('iframe');
            if (iframe) {
              var src = iframe.getAttribute('src');
              if (src) iframe.setAttribute('src', src);
            }
          }
        });
        thumbs.forEach(function (t) {
          var on = t.getAttribute('data-thumb-for') === String(mediaId);
          t.classList.toggle('is-active', on);
          if (on) t.setAttribute('aria-current', 'true'); else t.removeAttribute('aria-current');
        });
        if (matched && status) {
          var active = root.querySelector('.sitg-gallery__slide.is-active img, .sitg-gallery__slide.is-active video');
          var label = active && active.getAttribute('alt');
          status.textContent = label ? 'Showing: ' + label : 'Media changed';
        }
      }

      thumbs.forEach(function (t) {
        t.addEventListener('click', function () { activate(t.getAttribute('data-thumb-for')); });
      });

      root.addEventListener('keydown', function (e) {
        if (e.key !== 'ArrowLeft' && e.key !== 'ArrowRight') return;
        var list = Array.prototype.slice.call(thumbs);
        if (!list.length) return;
        var idx = list.findIndex(function (t) { return t.classList.contains('is-active'); });
        if (idx < 0) idx = 0;
        var next = e.key === 'ArrowRight' ? (idx + 1) % list.length : (idx - 1 + list.length) % list.length;
        list[next].focus();
        list[next].click();
        e.preventDefault();
      });

      if (root.getAttribute('data-variant-switching') === 'true') {
        function switchToVariantMedia(variant) {
          if (!variant || !variant.featured_media) return;
          activate(variant.featured_media.id);
        }
        document.addEventListener('variant:change', function (e) {
          if (e && e.detail && e.detail.variant) switchToVariantMedia(e.detail.variant);
        });
        var idInputs = document.querySelectorAll('form[action*="/cart/add"] input[name="id"]');
        idInputs.forEach(function (input) {
          input.addEventListener('change', function () {
            var vid = input.value;
            if (!vid || !window.SitgVariantsCache) return;
            var v = window.SitgVariantsCache[vid];
            if (v) switchToVariantMedia(v);
          });
        });
      }
    })();
  </script>
</product-info>

{% schema %}
{
  "name": "Product · Luhxe",
  "tag": "section",
  "class": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "enable_sticky_info",
      "label": "Sticky product info on desktop",
      "default": true
    },
    {
      "type": "header",
      "content": "Gallery"
    },
    {
      "type": "select",
      "id": "thumbnails_position",
      "label": "Thumbnails (desktop)",
      "default": "left",
      "options": [
        { "value": "bottom", "label": "Bottom" },
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" },
        { "value": "hidden", "label": "Hidden" }
      ]
    },
    {
      "type": "range",
      "id": "gallery_max_width",
      "min": 480,
      "max": 900,
      "step": 20,
      "unit": "px",
      "label": "Gallery max width",
      "default": 640
    },
    {
      "type": "checkbox",
      "id": "enable_variant_switching",
      "label": "Switch image when variant changes",
      "default": true
    },
    {
      "type": "header",
      "content": "Featured-in badge"
    },
    {
      "type": "image_picker",
