<div class="sitg">
<section class="sitg-founder" id="story">
  <div class="sitg-container">
    <div class="sitg-founder-inner reveal">
      <div class="sitg-founder-image-area">
        {%- if section.settings.founder_image != blank -%}
          <img
            class="sitg-founder-img"
            src="{{ section.settings.founder_image | image_url: width: 800 }}"
            alt="{{ section.settings.founder_image.alt | default: 'Founder' }}"
            loading="lazy"
          >
        {%- else -%}
          <div class="sitg-founder-img-placeholder">
            <div class="fip-icon">▶</div>
            <div class="fip-text">FOUNDER PHOTO</div>
          </div>
        {%- endif -%}
        <div class="sitg-founder-quote-card">
          <div class="fqc-quote">"{{ section.settings.pullquote }}"</div>
          <div class="fqc-name">{{ section.settings.pullquote_attribution }}</div>
        </div>
      </div>

      <div class="sitg-founder-content">
        <div class="section-eyebrow">{{ section.settings.eyebrow }}</div>
        <div class="section-title" style="font-size:clamp(32px,3.5vw,44px);margin-bottom:24px;">{{ section.settings.headline }}</div>
        <div class="sitg-founder-text">{{ section.settings.story }}</div>
        <div class="sitg-founder-sig">{{ section.settings.signature }}</div>
      </div>
    </div>
  </div>
</section>
</div>

{% schema %}
{
  "name": "SITG Founder Story",
  "settings": [
    { "type": "image_picker", "id": "founder_image", "label": "Founder photo" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Why I built this" },
    { "type": "textarea", "id": "headline", "label": "Headline (HTML allowed)", "default": "I LIVED OUT OF CARRY-ONS<br>FOR 11 YEARS." },
    {
      "type": "richtext",
      "id": "story",
      "label": "Founder story",
      "default": "<p>I spent 11 years as a flight attendant. Two thousand flights. Forty-seven countries. I lived out of carry-ons before any influencer made it a lifestyle.</p><p>And in all that time, I never owned a single bag I actually loved. The premium designer cases were beautiful but useless — no garment bay, no shoe compartment, scuffed in a month. The functional travel bags were ugly. <strong>Every bag I tried made me choose: beautiful, or practical. Never both.</strong></p><p>So I built one. HerVoyage is what I would have killed to own at 26. It's the bag I never had — the one that makes you look effortless when you're anything but.</p>"
    },
    { "type": "text", "id": "pullquote", "label": "Pull quote", "default": "I wasn't waiting for someone else to design it. So I built it myself." },
    { "type": "text", "id": "pullquote_attribution", "label": "Pull quote attribution", "default": "— Founder, HerVoyage" },
    { "type": "text", "id": "signature", "label": "Signature line", "default": "— Still travelling. Still HerVoyage." }
  ],
  "presets": [{ "name": "SITG Founder Story" }]
}
{% endschema %}
