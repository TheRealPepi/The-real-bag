<div class="sitg">
<section class="sitg-final-cta">
  <div class="sitg-container reveal">
    <h2>{{ section.settings.headline }}</h2>
    <a href="{{ section.settings.cta_link | default: '#shop' }}" class="btn-primary" style="font-size:17px;padding:18px 42px;">
      {{ section.settings.cta_text }}
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </a>
  </div>
</section>
</div>

<script src="{{ 'sitg-landing.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "SITG Final CTA",
  "settings": [
    { "type": "image_picker", "id": "section_image", "label": "Product/lifestyle image (displays above CTA button)" },
    { "type": "text", "id": "handwritten", "label": "Handwritten text", "default": "" },
    { "type": "textarea", "id": "headline", "label": "Headline (HTML allowed)", "default": "Your journey deserves a beautiful start." },
    { "type": "textarea", "id": "body", "label": "Body", "default": "" },
    { "type": "text", "id": "cta_text", "label": "CTA text", "default": "Get HerVoyage" },
    { "type": "url", "id": "cta_link", "label": "CTA link" }
  ],
  "blocks": [
    {
      "type": "proof_point",
      "name": "Proof point",
      "settings": [
        { "type": "text", "id": "number", "label": "Number", "default": "21" },
        { "type": "text", "id": "label", "label": "Label", "default": "Airlines verified" }
      ]
    }
  ],
  "presets": [
    {
      "name": "SITG Final CTA",
      "blocks": []
    }
  ]
}
{% endschema %}
