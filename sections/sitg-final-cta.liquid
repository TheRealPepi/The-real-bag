<div class="sitg">
<section class="sitg-final-cta">
  <div class="sitg-container reveal">
    <div class="fc-handwritten">{{ section.settings.handwritten }}</div>
    <h2>{{ section.settings.headline }}</h2>
    <p>{{ section.settings.body }}</p>
    {%- if section.settings.section_image != blank -%}
      <img
        class="sitg-final-cta-img"
        src="{{ section.settings.section_image | image_url: width: 800 }}"
        alt="{{ section.settings.section_image.alt | default: 'Still In The Game' }}"
        loading="lazy"
      >
    {%- endif -%}
    <a href="{{ section.settings.cta_link | default: '#sitg-buy' }}" class="btn-primary" style="font-size:17px;padding:18px 42px;">
      {{ section.settings.cta_text }}
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </a>
    <div class="sitg-final-proof">
      {%- for block in section.blocks -%}
        <div class="sitg-final-proof-item" {{ block.shopify_attributes }}>
          <div class="fp-num">{{ block.settings.number }}</div>
          <div class="fp-label">{{ block.settings.label }}</div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>
</div>

<script src="{{ 'sitg-landing.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "SITG Final CTA",
  "settings": [
    { "type": "image_picker", "id": "section_image", "label": "Product/lifestyle image (displays above CTA button)" },
    { "type": "text", "id": "handwritten", "label": "Handwritten text", "default": "Motion is lotion" },
    { "type": "textarea", "id": "headline", "label": "Headline (HTML allowed)", "default": "YOU'RE STILL IN THE GAME.<br>WE'RE HERE TO <span style=\"color:var(--sitg-amber)\">KEEP YOU THERE.</span>" },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Your body was built to move. To hike, to play, to lift, to live. Three capsules a day. Four mechanisms working together. One daily reminder of who you've always been." },
    { "type": "text", "id": "cta_text", "label": "CTA text", "default": "Start My Ritual" },
    { "type": "url", "id": "cta_link", "label": "CTA link" }
  ],
  "blocks": [
    {
      "type": "proof_point",
      "name": "Proof point",
      "settings": [
        { "type": "text", "id": "number", "label": "Number", "default": "50+" },
        { "type": "text", "id": "label", "label": "Label", "default": "Clinical trials" }
      ]
    }
  ],
  "presets": [
    {
      "name": "SITG Final CTA",
      "blocks": [
        { "type": "proof_point", "settings": { "number": "50+", "label": "Clinical trials" } },
        { "type": "proof_point", "settings": { "number": "90 Days", "label": "Money-back guarantee" } }
      ]
    }
  ]
}
{% endschema %}
