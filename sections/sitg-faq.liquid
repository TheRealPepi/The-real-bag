<div class="sitg">
<section class="sitg-faq" id="faq">
  <div class="sitg-container">
    <div class="sitg-faq-header reveal">
      <div class="section-eyebrow">{{ section.settings.eyebrow }}</div>
      <div class="section-title">{{ section.settings.headline }}</div>
    </div>
    <div class="sitg-faq-list reveal">
      {%- for block in section.blocks -%}
        <div class="sitg-faq-item" {{ block.shopify_attributes }}>
          <button class="sitg-faq-question">
            {{ block.settings.question }}
            <span class="fq-icon">+</span>
          </button>
          <div class="sitg-faq-answer">
            <p>{{ block.settings.answer }}</p>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>
</div>

{% schema %}
{
  "name": "SITG FAQ",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Questions" },
    { "type": "textarea", "id": "headline", "label": "Headline (HTML allowed)", "default": "STRAIGHT ANSWERS.<br>NO COMPROMISE." }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ item",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "Will HerVoyage actually fit as a carry-on?" },
        { "type": "textarea", "id": "answer", "label": "Answer", "default": "Yes — and we tested it on the smallest cabin sizers in the industry. HerVoyage measures 55×35×22 cm folded, fitting the carry-on rules of 21 major airlines including BA, easyJet, Ryanair, Lufthansa, Emirates, Delta, AA, KLM, Air France, JAL and ANA." }
      ]
    }
  ],
  "presets": [
    { "name": "SITG FAQ" }
  ]
}
{% endschema %}
