<div class="sitg">
<section class="sitg-timeline-section" id="sitg-timeline">
  <div class="sitg-container">
    <div class="sitg-timeline-header reveal">
      <div class="section-eyebrow">{{ section.settings.eyebrow }}</div>
      <div class="section-title">{{ section.settings.headline }}</div>
      <p class="section-subtitle" style="margin-left:auto;margin-right:auto;">{{ section.settings.subtitle }}</p>
    </div>
    <div class="sitg-timeline reveal">
      {%- for block in section.blocks -%}
        <div class="sitg-tl-item" {{ block.shopify_attributes }}>
          <div class="sitg-tl-content">
            <div class="sitg-tl-when">{{ block.settings.when }}</div>
            <div class="sitg-tl-what">{{ block.settings.what }}</div>
          </div>
          <div class="sitg-tl-dot"></div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>
</div>

{% schema %}
{
  "name": "SITG Timeline",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "What to expect" },
    { "type": "textarea", "id": "headline", "label": "Headline (HTML allowed)", "default": "REAL TIMELINES.<br>NOT MIRACLE PROMISES." },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle", "default": "Each ingredient activates on its own timeline. Here's what the clinical research says you can expect — not what marketing says you want to hear." }
  ],
  "blocks": [
    {
      "type": "milestone",
      "name": "Timeline milestone",
      "settings": [
        { "type": "text", "id": "when", "label": "When", "default": "DAY 5" },
        { "type": "textarea", "id": "what", "label": "What (HTML allowed)", "default": "<strong>Boswellia kicks in first.</strong> AprèsFlex begins reducing 5-LOX inflammation — the fastest onset of any botanical studied. You may notice morning stiffness starting to ease." }
      ]
    }
  ],
  "presets": [
    {
      "name": "SITG Timeline",
      "blocks": [
        { "type": "milestone", "settings": { "when": "DAY 5", "what": "<strong>Boswellia kicks in first.</strong> AprèsFlex begins reducing 5-LOX inflammation — the fastest onset of any botanical studied. You may notice morning stiffness starting to ease." } },
        { "type": "milestone", "settings": { "when": "WEEKS 2–4", "what": "<strong>Curcumin anti-inflammatory effects build.</strong> Meriva's phytosome delivery starts reducing COX-2 and NF-κB — a second inflammatory pathway now covered. PEA begins modulating pain signals via the endocannabinoid system." } },
        { "type": "milestone", "settings": { "when": "WEEKS 4–8", "what": "<strong>Full curcumin + PEA synergy.</strong> Inflammatory biomarkers (CRP, TNF-α) significantly reduced. Most people report noticeable improvement in daily activities — stairs, morning stiffness, exercise recovery." } },
        { "type": "milestone", "settings": { "when": "MONTHS 2–3", "what": "<strong>UC-II oral tolerance fully establishes.</strong> Your immune system is now reprogrammed to reduce immune-mediated cartilage breakdown. This is where structural, lasting benefit begins." } },
        { "type": "milestone", "settings": { "when": "MONTH 3+", "what": "<strong>All four mechanisms fully active.</strong> Deepening structural benefit from UC-II. Cumulative anti-inflammatory action. This is the long game — the benefit keeps building." } }
      ]
    }
  ]
}
{% endschema %}
