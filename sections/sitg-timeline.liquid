<div class="sitg">
<section class="sitg-timeline-section" id="sitg-timeline">
  <div class="sitg-container">
    <div class="sitg-timeline-header reveal">
      <div class="section-eyebrow">{{ section.settings.eyebrow }}</div>
      <div class="section-title">{{ section.settings.headline }}</div>
      <p class="section-subtitle" style="margin-left:auto;margin-right:auto;">{{ section.settings.subtitle }}</p>
    </div>
    <div class="sitg-timeline reveal">
      {%- for block in section.blocks -%}
        <div class="sitg-tl-item" {{ block.shopify_attributes }}>
          <div class="sitg-tl-content">
            <div class="sitg-tl-when">{{ block.settings.when }}</div>
            <div class="sitg-tl-what">{{ block.settings.what }}</div>
          </div>
          <div class="sitg-tl-dot"></div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>
</div>

{% schema %}
{
  "name": "SITG Timeline",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "What to expect" },
    { "type": "textarea", "id": "headline", "label": "Headline (HTML allowed)", "default": "FROM UNBOXING<br>TO TRIP TEN." },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle", "default": "Most luxury bags get worse with use. HerVoyage gets faster — every trip, you'll pack tighter, move quicker, and arrive more put-together than the last." }
  ],
  "blocks": [
    {
      "type": "milestone",
      "name": "Timeline milestone",
      "settings": [
        { "type": "text", "id": "when", "label": "When", "default": "DAY 1" },
        { "type": "textarea", "id": "what", "label": "What (HTML allowed)", "default": "<strong>HerVoyage arrives at your door.</strong> Unbox, hang it in your wardrobe, and watch the foldable structure reveal a full-length garment bay you didn't think a carry-on could hide." }
      ]
    }
  ],
  "presets": [
    { "name": "SITG Timeline" }
  ]
}
{% endschema %}
