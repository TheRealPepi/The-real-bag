          "options": [
            { "value": "check", "label": "✓ Check" },
            { "value": "x",     "label": "✗ X" },
            { "value": "text",  "label": "Custom text" }
          ],
          "default": "x"
        },
        { "type": "text", "id": "comp1_value",  "label": "Comp 1 value (if text)", "default": "—" },
        {
          "type": "select", "id": "comp2_type", "label": "Comp 2 value type",
          "options": [
            { "value": "check", "label": "✓ Check" },
            { "value": "x",     "label": "✗ X" },
            { "value": "text",  "label": "Custom text" }
          ],
          "default": "x"
        },
        { "type": "text", "id": "comp2_value",  "label": "Comp 2 value (if text)", "default": "—" }
      ]
    }
  ],
  "presets": [
    {
      "name": "SITG Comparison v2",
      "blocks": [
        {
          "type": "row",
          "settings": {
            "row_label":    "Pain pathways covered",
            "us_type":      "text",
            "us_value":     "4",
            "comp1_type":   "text",
            "comp1_value":  "1",
            "comp2_type":   "text",
            "comp2_value":  "1–2"
          }
        },
        {
          "type": "row",
          "settings": {
            "row_label":    "Clinically dosed ingredients",
            "us_type":      "check",
            "comp1_type":   "x",
            "comp2_type":   "x"
          }
        },
        {
          "type": "row",
          "settings": {
            "row_label":    "All doses disclosed",
            "us_type":      "check",
            "comp1_type":   "check",
            "comp2_type":   "x"
          }
        },
        {
          "type": "row",
          "settings": {
            "row_label":    "Endocannabinoid support (PEA)",
            "us_type":      "check",
            "comp1_type":   "x",
            "comp2_type":   "x"
          }
        },
        {
          "type": "row",
          "settings": {
            "row_label":    "Daily pills",
            "us_type":      "text",
            "us_value":     "2",
            "comp1_type":   "text",
            "comp1_value":  "2–3",
            "comp2_type":   "text",
            "comp2_value":  "8–12"
          }
        },
        {
          "type": "row",
          "settings": {
